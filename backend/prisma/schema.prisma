generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())

  email String @unique

  password String

  resumes Resume[]

  createdAt DateTime @default(now())
}

model Resume {
  id String @id @default(uuid())

  title String

  data Json

  userId String?

  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}
